--- !u!114 &6458252331221896220
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6458252331221896221}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2bd0415434d92fa428f1ff64013530bb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _anim: {fileID: 6458252331221896218}
  _verText: {fileID: 6458252331833269909}
  _localizeTMPro: {fileID: 6458252332150589230}
  _text_ENG: "Known Issues:\r\n\t- Veemon (P-1117) Cost reduction will visually show
    the reduction, even though you will\r\n\t  end up paying full cost (after it's
    once per turn use)\r\n\t- Mega Digimon Assembly! not functional\r\n\t- Effects
    given to another card do not always show up on card details\r\n\t- All deck lists
    will be cleared due to new local directory for decklists\r\n\t- See other issues
    in bug tracking document\r\n\r\nUpdates:\r\n\t- Several Bug fixes (see below)\r\n\t-
    EX6 set added\r\n\t- Promos 131-138 & 143-151 added \r\n\t- Updated profanity
    filter list\r\n\t- Added Feature that decklists save locally in directory (Assets/Decklists)\r\n\t-
    Decklist name size increased from 15 to 28 characters\r\n\t- Minor performance
    enhancement to multiple digimon on board\r\n\t- Capped framerate at 60\r\n\t-
    Auto Updater testing\r\n\r\nCard Updates:\r\n\t- Dragon's Breath\tBT16-094\r\n\t-
    Tankdramon\tBT16-060\r\n\t- MegaGargomon\tST17-08\r\n\t- Darkdramon\tBT16-065\r\n\t-
    TyrantKabuterimon\tBT16-048\r\n\t- MailBirdramon\tEX4-018\r\n\t- Shakkoumon\tBT16-063\r\n\t-
    DoruGreymon\tBT16-061\r\n\t- Garudamon (X Antibody)\tBT16-011\r\n\t- Final Excalibur\tEX6-067\r\n\t-
    Ophanimon\tEX6-027\r\n\t- Sagomon\tEX6-024\r\n\t- Silphymon\tBT16-012\r\n\t-
    Amphimon\tLM-005\r\n\t- Spadamon\tEX6-037\r\n\t- Galemon\tP-132\r\n\t- Shoemon\tP-134\r\n\t-
    Shoeshoemon\tP-135\r\n\t- Drimogemon\tP-143\r\n\t- Myotismon (X Antibody)\tP-145\r\n\t-
    Reload Plug-In Q\tP-146\r\n\t- Gokuumon\tEX6-023\r\n\t- Terriermon\tST17-02\r\n\t-
    Sethmon\tBT16-070\r\n\t- Zubamon\tEX6-007\r\n\t- Durandamon\tEX6-010\r\n\t- RagnaLoardmon\tEX6-011\r\n\t-
    Luxmon\tEX6-017\r\n\t- Seraphimon\tEX6-028\r\n\t- Mastemon\tEX6-029\r\n\t- Ludomon\tEX6-038\r\n\t-
    RaijiLudomon\tEX6-042\r\n\t- Boogiemon\tEX6-047\r\n\t- Witchmon\tEX6-048\r\n\t-
    Bastemon\tEX6-052\r\n\t- UltimateChaosmon\tEX6-062\r\n\t- Pandemonium Lost\tEX6-071\r\n\t-
    Angewomon\tEX6-022\r\n\t- Tactimon\tBT10-084\r\n\t- Zanmetsumon\tBT16-062\r\n\t-
    Invincible Dragon Insect Combo\tBT16-092\r\n\t- Gatomon\tEX6-020\r\n\t- Kurisarimon\tEX6-039\r\n\t-
    Descent of the Three Great Angels\tEX6-068\r\n\t- Ogudomon\tEX6-073\r\n\t- Barbamon\tEX6-059\r\n\t-
    Beast Storm Dance of Love\tBT16-091\r\n\t- Zhuqiaomon\tBT8-019\r\n\t- Dinobeemon\tBT16-077\r\n\t-
    Astamon\tBT12-081\r\n\t- Magnadramon\tBT15-042\r\n\t- Mythical Arms of Salvation!\tEX6-065\r\n\t-
    Antylamon\tEX6-034\r\n\t- Lucemon: Chaos Mode\tEX6-054\r\n\t- Belphemon: Rage
    Mode\tEX6-060\r\n\t- Rise of the Seven Great Demon Lords\tEX6-069\r\n\t- Regulusmon\tLM-017\r\n\t-
    ExVeemon\tBT16-018\r\n\t- Gate of Deadly Sins\tEX6-006\r\n\t- Amphimon\tRB1-016\r\n\t-
    Lampmon\tBT12-044\r\n\t- Ancient Angel of Steel\tBT16-097\r\n\t- Mirei Mikagura\tEX6-074\r\n\t-
    Holy Sunshine\tBT11-101\r\n\t- Demonic Disaster\tBT5-106\r\n\t- Publimon\tBT16-056\r\n\t-
    Cherubimon\tEX6-035\r\n\t- MirageGaogamon: Burst Mode\tBT13-033\r\n\t- Shine
    of Bee\tBT16-095\r\n\t- Salamon\tEX6-016\r\n\t- Tsukaimon\tEX6-045\r"
  _text_JPN: 
  _scroll: {fileID: 6458252331812644436}
