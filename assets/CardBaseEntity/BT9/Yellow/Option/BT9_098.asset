  SecurityEffectDiscription_JPN: "\u3010\u30BB\u30AD\u30E5\u30EA\u30C6\u30A3\u3011\u81EA\u5206\u306E\u30C8\u30E9\u30C3\u30B7\u30E5\u306E\u540D\u79F0\u306B\u300C\u30DE\u30B0\u30CA\u30E2\u30F3\u300D\u3092\u542B\u3080\u30AB\u30FC\u30C91\u679A\u3092\u624B\u672D\u306B\u623B\u3057\u3001\u3053\u306E\u30AB\u30FC\u30C9\u3092\u624B\u672D\u306B\u52A0\u3048\u308B\u3002"
