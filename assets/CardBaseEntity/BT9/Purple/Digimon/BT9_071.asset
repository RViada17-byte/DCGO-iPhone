  EffectDiscription_JPN: "\u3010\u767B\u5834\u6642\u3011\u81EA\u5206\u306E\u30C7\u30C3\u30AD\u306E\u4E0A\u304B\u30893\u679A\u30AA\u30FC\u30D7\u30F3\u3059\u308B\u3002\u305D\u306E\u4E2D\u306E\u7279\u5FB4\u306B\u300C\u30A2\u30F3\u30C7\u30C3\u30C9\u578B\u300D\u304B\u300C\u9B54\u7363\u578B\u300D\u3092\u542B\u3080\u30AB\u30FC\u30C91\u679A\u3092\u624B\u672D\u306B\u52A0\u3048\u30011\u679A\u3092\u7834\u68C4\u3059\u308B\u3002\u6B8B\u308A\u306F\u597D\u304D\u306A\u9806\u756A\u3067\u30C7\u30C3\u30AD\u306E\u4E0B\u306B\u623B\u3059\u3002"
  EffectDiscription_ENG: '[On Play] Reveal the top 3 cards of your deck. Add 1 card
    with [Undead] or [Dark Animal] in its traits among them to your hand and trash
    1 card with [Undead] or [Dark Animal] in its traits among them. Place the rest
    at the bottom of your deck in any order.'
  InheritedEffectDiscription_JPN: "\u3010\u30A2\u30BF\u30C3\u30AF\u6642\u3011\u3053\u306E\u30C7\u30B8\u30E2\u30F3\u3092\u3001\u81EA\u5206\u306E\u30C8\u30E9\u30C3\u30B7\u30E5\u306E\u7279\u5FB4\u306B\u300C\u30A2\u30F3\u30C7\u30C3\u30C9\u578B\u300D\u304B\u300C\u9B54\u7363\u578B\u300D\u3092\u6301\u3064\u30C7\u30B8\u30E2\u30F3\u30AB\u30FC\u30C91\u679A\u306B\u9032\u5316\u30B3\u30B9\u30C8\u3092\u652F\u6255\u3063\u3066\u9032\u5316\u3067\u304D\u308B\u3002"
  InheritedEffectDiscription_ENG: '[When Attacking] This Digimon may digivolve into
    a Digimon card with [Undead] or [Dark Animal] in its traits from your trash for
    its digivolution cost.'
